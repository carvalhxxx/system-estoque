# ============================================================
# CONFIGURAÇÃO DA API - Sistema de Estoque
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta da API
PORT=3001

# SQL Server Express
DB_SERVER=localhost\\SQLEXPRESS
DB_DATABASE=SistemaEstoque
DB_TRUSTED_CONNECTION=true
# Se usar autenticação SQL ao invés de Windows:
# DB_USER=sa
# DB_PASSWORD=SuaSenha

# JWT
JWT_SECRET=troque-por-uma-chave-secreta-bem-longa-aqui
JWT_EXPIRES_IN=7d

# CORS - origens permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
